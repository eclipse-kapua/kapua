<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
                      http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.0.xsd"
  logicalFilePath="KapuaDB/changelog-user-2.1.0.xml">

    <changeSet id="user-tag-2.1.0-create_table" author="eurotech">

        <createTable tableName="usr_user_tag">
            <column name="user_id" type="bigint(21) unsigned">
                <constraints nullable="false" primaryKey="true" checkConstraint=">= 0"/>
            </column>
            <column name="tag_id" type="bigint(21) unsigned">
                <constraints nullable="false" primaryKey="true" checkConstraint=">= 0"/>
            </column>
        </createTable>

        <addForeignKeyConstraint
            constraintName="user_tag-user_id-fk"
            baseTableName="usr_user_tag"
            baseColumnNames="user_id"
            referencedTableName="usr_user"
            referencedColumnNames="id"
            onDelete="CASCADE"/>

        <rollback>
            <dropTable tableName="usr_user_tag"/>
        </rollback>
    </changeSet>

</databaseChangeLog>
